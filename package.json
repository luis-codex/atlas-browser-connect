{
	"name": "atlas-browser-connect",
	"version": "0.1.1",
	"type": "module",
	"license": "MIT",
	"scripts": {
		"build": "bun run scripts/build.ts",
		"check": "bunx --bun @biomejs/biome check .",
		"check:fix": "bunx --bun @biomejs/biome check --write .",
		"format": "bunx --bun @biomejs/biome format --write .",
		"lint": "bunx --bun @biomejs/biome lint .",
		"lint:fix": "bunx --bun @biomejs/biome lint --write .",
		"mcp": "node dist/mcp/index.js",
		"mcp:dev": "bun run apps/mcp-server/src/index.ts",
		"native-messaging-host": "bun run apps/native-messaging-host/src/index.ts",
		"package": "bun run scripts/package.ts",
		"test": "bun test",
		"typecheck": "tsc --noEmit"
	},
	"private": true,
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.29.0",
		"zod": "^4.4.2"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.14",
		"@types/bun": "latest",
		"@types/chrome": "0.1.40",
		"typescript": "^5.9.3"
	}
}
